@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "New Service Request";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">New Service Request</h5>
            </div>
            <div class="card-body">

               
                <div class="alert alert-info mb-4">
                    <strong>Note:</strong> Service requests can only be
                    created against <strong>Active</strong> contracts.
                    Expired or On Hold contracts are not shown.
                </div>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="ContractId"
                               class="form-label fw-semibold">Contract</label>
                        <select asp-for="ContractId"
                                asp-items="ViewBag.Contracts"
                                class="form-select">
                            <option value="">-- Select Active Contract --</option>
                        </select>
                        <span asp-validation-for="ContractId"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description"
                               class="form-label fw-semibold"></label>
                        <textarea asp-for="Description"
                                  class="form-control" rows="3"
                                      placeholder="Describe the service request...">
                        </textarea>
                            <span asp-validation-for="Description"
                                  class="text-danger small"></span>
                        </div>

                       
                        <div class="p-3 bg-light rounded border mb-3">
                            <h6 class="fw-bold mb-3">
                                Cost & Currency Conversion
                            </h6>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CostUSD"
                                           class="form-label fw-semibold">
                                        Cost (USD)
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="CostUSD"
                                               type="number"
                                               step="0.01" min="0"
                                               class="form-control"
                                               placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="CostUSD"
                                          class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">
                                        Cost (ZAR)
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">R</span>
                                        <input type="text"
                                               id="zarPreview"
                                               class="form-control"
                                               placeholder="Auto-calculated"
                                               readonly />
                                    </div>
                                    <small class="text-muted">
                                        Calculated automatically using
                                        live exchange rate on save.
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                Submit Request
                            </button>
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
        <script>
            // Live ZAR preview using exchange rate API
            const costUsdInput = document.getElementById('CostUSD');
            const zarPreview = document.getElementById('zarPreview');
            let exchangeRate = null;

            // Fetch live rate on page load
            fetch('https://open.er-api.com/v6/latest/USD')
                .then(res => res.json())
                .then(data => {
                    exchangeRate = data.rates.ZAR;
                })
                .catch(() => {
                    zarPreview.placeholder = 'Rate unavailable';
                });

            // Update ZAR preview as user types USD amount
            costUsdInput.addEventListener('input', () => {
                const usd = parseFloat(costUsdInput.value);
                if (!isNaN(usd) && exchangeRate) {
                    zarPreview.value = 'R ' + (usd * exchangeRate)
                        .toFixed(2)
                        .replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                } else {
                    zarPreview.value = '';
                }
            });
        </script>
    }
