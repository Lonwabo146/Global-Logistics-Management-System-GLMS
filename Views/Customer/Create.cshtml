@model GLMS.Models.Customer

@{
    ViewData["Title"] = "New Customer";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">New Customer</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger d-none"
                         id="validationSummary">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactDetails"
                               class="form-label fw-semibold"></label>
                        <input asp-for="ContactDetails" class="form-control" />
                        <span asp-validation-for="ContactDetails"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Region"
                               class="form-label fw-semibold"></label>
                        <input asp-for="Region" class="form-control" />
                        <span asp-validation-for="Region"
                              class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Save Customer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Show validation summary if it has content
        const vs = document.getElementById('validationSummary');
        if (vs && vs.innerText.trim() !== '') {
            vs.classList.remove('d-none');
        }
    </script>
}