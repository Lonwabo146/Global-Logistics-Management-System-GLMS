@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white
                d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Contract Details</h5>
                <a asp-action="Index" class="btn btn-sm btn-light">← Back</a>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Customer</dt>
                    <dd class="col-sm-9">@Model.Customer?.Name</dd>

                    <dt class="col-sm-3">Service Level</dt>
                    <dd class="col-sm-9">@Model.ServiceLevel</dd>

                    <dt class="col-sm-3">Start Date</dt>
                    <dd class="col-sm-9">
                        @Model.StartDate.ToString("dd MMM yyyy")
                    </dd>

                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">
                        @Model.EndDate.ToString("dd MMM yyyy")
                    </dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge @GetBadge(Model.Status)">
                            @Model.Status
                        </span>
                    </dd>

                    <dt class="col-sm-3">Signed Agreement</dt>
                    <dd class="col-sm-9">
                        @if (Model.SignedAgreementPath != null)
                        {
                            <a asp-action="Download"
                                   asp-route-id="@Model.ContractId"
                                   class="btn btn-sm btn-outline-success">
                                Download PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not uploaded</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <h5 class="fw-bold mb-3">
            Service Requests (@Model.ServiceRequests.Count)
        </h5>

        @if (Model.ServiceRequests.Any())
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th>Description</th>
                                <th>Cost (USD)</th>
                                <th>Cost (ZAR)</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sr in Model.ServiceRequests)
                            {
                                <tr>
                                    <td>@sr.Description</td>
                                    <td>$@sr.CostUSD.ToString("N2")</td>
                                    <td>R @sr.CostZAR.ToString("N2")</td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            @sr.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p class="text-muted">
                No service requests linked to this contract.
            </p>
        }
    </div>
</div>

@functions {
    string GetBadge(GLMS.Models.ContractStatus status) => status switch
    {
        GLMS.Models.ContractStatus.Active => "bg-success",
        GLMS.Models.ContractStatus.Expired => "bg-danger",
        GLMS.Models.ContractStatus.OnHold => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}