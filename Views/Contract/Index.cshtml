@model IEnumerable<GLMS.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Contracts</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Contract</a>
</div>


<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">
        Search & Filter
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Start Date From</label>
                    <input type="date" name="startDate"
                           value="@ViewBag.StartDate"
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date To</label>
                    <input type="date" name="endDate"
                           value="@ViewBag.EndDate"
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues(
                            typeof(GLMS.Models.ContractStatus)))
                        {
                            <option value="@s"
                                    selected="@(ViewBag.Status?.ToString() == s.ToString())">
                                @s
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit"
                            class="btn btn-primary w-100">
                        Search
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary w-100">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Customer</th>
                    <th>Service Level</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Agreement</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            @contract.Customer?.Name
                        </td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("dd MMM yyyy")</td>
                        <td>@contract.EndDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @GetBadge(contract.Status)">
                                @contract.Status
                            </span>
                        </td>
                        <td>
                            @if (contract.SignedAgreementPath != null)
                            {
                                <a asp-action="Download"
                                       asp-route-id="@contract.ContractId"
                                       class="btn btn-sm btn-outline-success">
                                    Download PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">None</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details"
                               asp-route-id="@contract.ContractId"
                               class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit"
                               asp-route-id="@contract.ContractId"
                               class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete"
                               asp-route-id="@contract.ContractId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7"
                            class="text-center text-muted py-4">
                            No contracts found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetBadge(GLMS.Models.ContractStatus status) => status switch
    {
        GLMS.Models.ContractStatus.Active => "bg-success",
        GLMS.Models.ContractStatus.Expired => "bg-danger",
        GLMS.Models.ContractStatus.OnHold => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
