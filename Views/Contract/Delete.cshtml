@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Delete Contract</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Are you sure you want to delete this contract?
                    All linked service requests will also be affected.
                </p>
                <dl class="row">
                    <dt class="col-sm-4">Customer</dt>
                    <dd class="col-sm-8">@Model.Customer?.Name</dd>

                    <dt class="col-sm-4">Service Level</dt>
                    <dd class="col-sm-8">@Model.ServiceLevel</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ContractId" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            Yes, Delete
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>