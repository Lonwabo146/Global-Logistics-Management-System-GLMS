@model GLMS.Models.Contract

@{
    ViewData["Title"] = "New Contract";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">New Contract</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CustomerId"
                               class="form-label fw-semibold"></label>
                        <select asp-for="CustomerId"
                                asp-items="ViewBag.Customers"
                                class="form-select">
                            <option value="">-- Select Customer --</option>
                        </select>
                        <span asp-validation-for="CustomerId"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ServiceLevel"
                               class="form-label fw-semibold"></label>
                        <input asp-for="ServiceLevel" class="form-control"
                               placeholder="e.g. Standard, Premium" />
                        <span asp-validation-for="ServiceLevel"
                              class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="StartDate"
                                   type="date" class="form-control" />
                            <span asp-validation-for="StartDate"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="EndDate"
                                   type="date" class="form-control" />
                            <span asp-validation-for="EndDate"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                   
                    <div class="mb-3 p-3 bg-light rounded border">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox"
                                   name="isInternational" id="isInternational"
                                   value="true" />
                            <label class="form-check-label fw-semibold"
                                   for="isInternational">
                                International Contract
                            </label>
                        </div>
                        <small class="text-muted">
                            International contracts start as
                            <strong>Active</strong> and are prefixed
                            with [INTL]. Standard contracts start
                            as <strong>Draft</strong>.
                        </small>
                    </div>

                   
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Signed Agreement (PDF only)
                        </label>
                        <input type="file" name="pdfFile"
                               class="form-control" accept=".pdf" />
                        <div class="form-text">
                            Only .pdf files are accepted.
                        </div>
                        <span asp-validation-for="SignedAgreementPath"
                              class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Save Contract
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}